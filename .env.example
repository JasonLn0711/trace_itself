# Use development locally. Switch to production for any real remote deployment,
# especially before exposing the app through Tailscale Serve or Tailscale Funnel.
APP_ENV=development
POSTGRES_DB=trace_itself
POSTGRES_USER=trace_itself
POSTGRES_PASSWORD=change-me-db-password

DATABASE_URL=postgresql+psycopg://trace_itself:change-me-db-password@db:5432/trace_itself
SECRET_KEY=change-me-long-random-secret
# Dedicated key for encrypting stored provider API secrets.
# Required in production and strongly recommended in all environments.
CREDENTIALS_SECRET_KEY=
DEFAULT_LLM_RUNS_PER_24H=3
DEFAULT_MAX_AUDIO_SECONDS_PER_REQUEST=18000
INITIAL_ADMIN_USERNAME=owner
INITIAL_ADMIN_DISPLAY_NAME=Owner
INITIAL_ADMIN_PASSWORD=change-me-strong-login-password
# Backward-compatible fallback used only if INITIAL_ADMIN_PASSWORD is unset.
APP_PASSWORD=change-me-strong-login-password
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=5
# Keep false for localhost-only testing.
# Set true when you access the app over HTTPS through Tailscale Serve or Tailscale Funnel.
SESSION_COOKIE_SECURE=false
SESSION_IDLE_TIMEOUT_MINUTES=5
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PROXY_TARGET=http://backend:8000
ASR_MODEL_NAME=SoybeanMilk/faster-whisper-Breeze-ASR-25
# Recommended on the NVIDIA lab machine. The default docker-compose.yml now requests the NVIDIA GPU for the backend.
# If the NVIDIA Container Toolkit is not installed yet, temporarily switch these back to cpu / float32.
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=float16
ASR_CPU_THREADS=4
ASR_LIVE_SAMPLE_RATE=16000
ASR_LIVE_PARTIAL_INTERVAL_MS=1500
ASR_LIVE_COMMIT_SILENCE_MS=1200
ASR_LIVE_MAX_WINDOW_SECONDS=18
ASR_LIVE_PROMPT_TAIL_WORDS=48
ASR_LIVE_VAD_THRESHOLD=0.45
ASR_LIVE_VAD_MIN_SILENCE_MS=450
ASR_LIVE_VAD_SPEECH_PAD_MS=180
ASR_LIVE_PREVIEW_BEAM_SIZE=1
ASR_LIVE_FINAL_BEAM_SIZE=5
ASR_LIVE_MAX_CHUNK_KB=2048
NEXT_PUBLIC_ASR_LIVE_TRANSPORT_TARGET_KB=32
NEXT_PUBLIC_ASR_LIVE_TRANSPORT_MAX_WAIT_MS=1000
ASR_LIVE_MAX_UTTERANCE_SECONDS=45
ASR_LIVE_MAX_SESSIONS_PER_USER=2
ASR_MAX_UPLOAD_MB=512
MEETING_MAX_UPLOAD_MB=512
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# These host ports stay bound to 127.0.0.1 by docker-compose.yml.
# Do not expose them with public firewall or router rules.
# Publish the frontend through Tailscale Serve for private access or Tailscale Funnel for intentional public exposure.
# If you use Funnel, the login page becomes public and will receive normal internet scanner traffic.
FRONTEND_PORT=3000
BACKEND_PORT=8000
