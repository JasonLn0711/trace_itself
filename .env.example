POSTGRES_DB=trace_itself
POSTGRES_USER=trace_itself
POSTGRES_PASSWORD=change-me-db-password

DATABASE_URL=postgresql+psycopg://trace_itself:change-me-db-password@db:5432/trace_itself
SECRET_KEY=change-me-long-random-secret
INITIAL_ADMIN_USERNAME=owner
INITIAL_ADMIN_DISPLAY_NAME=Owner
INITIAL_ADMIN_PASSWORD=change-me-strong-login-password
# Backward-compatible fallback used only if INITIAL_ADMIN_PASSWORD is unset.
APP_PASSWORD=change-me-strong-login-password
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=5
# Keep false for localhost-only testing.
# Set true when you access the app over HTTPS through Tailscale Serve on your lab server.
SESSION_COOKIE_SECURE=false
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PROXY_TARGET=http://backend:8000
ASR_MODEL_NAME=MediaTek-Research/Breeze-ASR-25
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=float32
ASR_CPU_THREADS=4
ASR_CHUNK_LENGTH_SECONDS=30
ASR_MAX_UPLOAD_MB=25
MEETING_MAX_UPLOAD_MB=120
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# These host ports stay bound to 127.0.0.1 by docker-compose.yml.
# Do not expose them publicly; publish the frontend privately with Tailscale Serve instead.
FRONTEND_PORT=3000
BACKEND_PORT=8000
