POSTGRES_DB=trace_itself
POSTGRES_USER=trace_itself
POSTGRES_PASSWORD=change-me-db-password

DATABASE_URL=postgresql+psycopg://trace_itself:change-me-db-password@db:5432/trace_itself
SECRET_KEY=change-me-long-random-secret
APP_PASSWORD=change-me-strong-login-password
# Keep false for localhost-only testing. Set true when you access the app over HTTPS on your lab server.
SESSION_COOKIE_SECURE=false
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

FRONTEND_PORT=3000
BACKEND_PORT=8000
